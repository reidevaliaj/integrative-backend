APP_NAME=Integrative Backend
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
